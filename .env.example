# Server
HOST=0.0.0.0
PORT=8000

# Default LLM provider (openai / deepseek / anthropic / gemini)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-5.4

# API Keys (provide at least one)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Paper parsing (optional: MinerU for high-fidelity PDF parsing)
MINERU_API_KEY=
MINERU_API_URL=

# Image generation (optional)
IMAGE_BACKEND=gemini
